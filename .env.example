# Template for .env (which is gitignored). Copy to .env and fill in:  cp .env.example .env
# Secrets are used only for one-time SSH-key install + read-only discovery.

# --- Proxmox nodes (same root password on all three) ---
NODE_ROOT_PASSWORD=
PVE_NODES=192.168.0.2,192.168.0.3,192.168.0.4

# --- QNAP (ai-storage) ---
QNAP_SSH_HOST=192.168.1.225
QNAP_SSH_USER=admin
QNAP_ADMIN_PASSWORD=
QNAP_HTTP_HOST=ai-storage
QNAP_HTTP_PORT=8080

