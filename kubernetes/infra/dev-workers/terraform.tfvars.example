# Copy to terraform.tfvars (gitignored) and fill in. Reuse the SAME pve API token + control-node
# SSH key as the runners module (kubernetes/infra/runners/terraform.tfvars).
#
#   cp terraform.tfvars.example terraform.tfvars
#   tofu -chdir=kubernetes/infra/dev-workers init
#   tofu -chdir=kubernetes/infra/dev-workers apply        # or: just dev-workers-apply
#
# IPs .37/.38/.39 are free static addresses inside the reserved block — no router change needed.

pve_endpoint     = "https://192.168.0.2:8006/"
pve_api_token    = "tofu@pve!tofu=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
pve_insecure     = true
pve_ssh_username = "root"
pve_ssh_key_path = "~/.ssh/id_ed25519"

# Control-node public key seeded into the cloud-init `c4` user (so Ansible can SSH in).
dev_worker_ssh_public_key = "ssh-ed25519 AAAA... chifor@gmail.com"

# ---- optional sizing overrides (defaults: 8 vCPU / 16 GiB balloon ceiling, 2 GiB floor / 40+128 GiB) ----
# dev_worker_memory_mib   = 12288   # lower the ceiling further if a large GPU VRAM carve makes a node tight
# dev_worker_workspace_gb = 160
