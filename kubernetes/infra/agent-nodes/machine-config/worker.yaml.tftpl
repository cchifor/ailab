machine:
  # AgentForge v2 dedicated compute pool. The label lets workloads target the pool
  # (RuntimeClass scheduling, nodeSelector); the taint keeps everything ELSE off it so agent/sandbox
  # pods (which carry the matching toleration) own these nodes.
  nodeLabels:
    ailab.io/agent-pool: "true"
  nodeTaints:
    dedicated: agent:NoSchedule
  install:
    disk: /dev/sda # matches controlplane.yaml.tftpl
  network:
    nameservers: ${nameservers}
    interfaces:
      - deviceSelector:
          driver: virtio_net
        dhcp: false
        addresses:
          - ${node_ip}/${prefix}
        routes:
          - network: 0.0.0.0/0
            gateway: ${gateway}
        # NO vip: workers do not carry the control-plane VIP (that is CP-only, controlplane.yaml.tftpl).
  registries:
    mirrors:
      # Pull docker.io through Google's anonymous pull-through cache to dodge Docker Hub rate limits
      # (HTTP 429), same as the CPs (controlplane.yaml.tftpl).
      docker.io:
        endpoints:
          - https://mirror.gcr.io
# NO cluster: stanza — a worker has no etcd/controllerManager/scheduler/allowSchedulingOnControlPlanes.
#
# ── P2 (spec §1b + §2): Kata + gVisor. The runtimes ship as Talos SYSTEM EXTENSIONS baked into the
#    boot IMAGE via the Image Factory schematic (../image.tf: siderolabs/kata-containers +
#    siderolabs/gvisor in var.talos_extensions), NOT config_patches — the agent pool has its OWN image
#    (staged via scripts/stage-talos-image.sh, imported in ../main.tf). The kernel modules below are the
#    machine-config HALF of that work: vhost_net/vhost_vsock accelerate Kata's microVM networking (and
#    vhost_vsock is the agent<->guest transport). Requires nested virt on the hosts (kvm_amd nested=1,
#    docs/runbooks/agent-nodes.md) + cpu.type=host (../main.tf) so /dev/kvm exists in the worker. The
#    RuntimeClasses (kata → handler `kata`; gvisor → handler `runsc`) are auto-registered by the
#    extensions and live in kubernetes/apps/infrastructure/agentforge-runtimeclasses/. ──
  kernel:
    modules:
      - name: vhost_net
      - name: vhost_vsock
