{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "labels": ["renovate"],
  "dependencyDashboardLabels": ["renovate"],
  "ignorePaths": ["kubernetes/apps/clusters/**/flux-system/gotk-components.yaml"],
  "kubernetes": {
    "managerFilePatterns": ["/kubernetes/apps/.+\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "description": "Track tool versions annotated with `# renovate:` in Ansible vars (e.g. the live zot binary on the registry LXC)",
      "customType": "regex",
      "managerFilePatterns": ["/ansible/.+\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+\\w+:\\s*\"?(?<currentValue>[^\"\\s#]+)\"?"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Group kube-prometheus-stack + its CRDs",
      "matchPackageNames": ["/kube-prometheus-stack/"],
      "groupName": "kube-prometheus-stack"
    }
  ]
}
