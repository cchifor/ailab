# Copy to registry.sops.yaml, fill values, then encrypt in place:
#   sops --encrypt --in-place ansible/secrets/registry.sops.yaml
# (the .sops.yaml registry creation_rule encrypts exactly these two keys).

# Password for the authenticated push user 'ci' (anonymous clients get read-only pull).
registry_ci_password: "CHANGE-ME-strong-random-password"

# Cloudflare API token with Zone:DNS:Edit on chifor.me — used by certbot DNS-01 to issue the
# Let's Encrypt cert for registry.chifor.me. Same scoped token the cloudflare tofu module uses
# (.env CLOUDFLARE_API_TOKEN).
cloudflare_dns_api_token: "CHANGE-ME-cloudflare-dns-edit-token"

# Plaintext of the Authelia OIDC client secret for the zot web-UI SSO login. The matching pbkdf2
# HASH lives in kubernetes/apps/apps/auth/authelia-config.yaml (client_id 'registry'). Generate the
# hash with: kubectl exec -n auth deploy/authelia -- authelia crypto hash generate pbkdf2 \
#   --variant sha512 --password '<this value>'
registry_oidc_client_secret: "CHANGE-ME-authelia-oidc-client-secret"
