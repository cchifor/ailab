# Template for ansible/secrets/dev-worker.sops.yaml (the real file is SOPS-encrypted + committed).
# Only needed if you enable a secret-backed feature (restic / cloudflared / password auth) in
# group_vars/dev_workers.yml. To create the encrypted file:
#
#   cp ansible/secrets/dev-worker.sops.yaml.example ansible/secrets/dev-worker.sops.yaml
#   # edit the values below, then encrypt in place (uses the .sops.yaml dev-worker creation_rule):
#   sops --encrypt --in-place ansible/secrets/dev-worker.sops.yaml
#   git add ansible/secrets/dev-worker.sops.yaml
#
# The values are decrypted at play time by dev-workers.yml's pre_task (community.sops.load_vars).

# restic repo encryption password (when dev_worker_enable_restic: true)
dev_worker_restic_password: "CHANGE-ME-strong-random"

# Cloudflare tunnel token (when dev_worker_enable_cloudflared: true)
dev_worker_cf_tunnel_token: ""

# c4 SSH/login password (when dev_worker_enable_password_auth: true)
dev_worker_admin_password: ""

# Gitea forge git token (chifor read/write:repository) for git.chifor.me access — ADR 0017.
# See roles/dev_worker/tasks/git_forge.yml. Mint it in Gitea (chifor -> Settings -> Applications).
dev_worker_gitea_token: ""

# ---- agentforge (when dev_worker_enable_agentforge: true — ADR 0018) ----
# All six are asserted non-empty by roles/dev_worker/tasks/agentforge.yml when the feature is on.
# Minting: cchifor/agentforge's scripts/bootstrap_gitea.py creates the 4 bot users + minimally-scoped
# PATs and the org-webhook HMAC, printing each secret ONCE (they are never logged elsewhere) — paste
# them here in the same session. The litellm key is the litellm-local master key
# (sops -d kubernetes/apps/apps/ai/litellm-local-secret.sops.yaml). See docs/runbooks/agentforge.md.
dev_worker_agentforge_webhook_secret: "CHANGE-ME-webhook-hmac"
dev_worker_agentforge_litellm_key: "sk-local-CHANGE-ME"
dev_worker_agentforge_planner_token: "CHANGE-ME-planner-bot-pat"
dev_worker_agentforge_tester_token: "CHANGE-ME-tester-bot-pat"
dev_worker_agentforge_impl_token: "CHANGE-ME-impl-bot-pat"
dev_worker_agentforge_reviewer_token: "CHANGE-ME-reviewer-bot-pat"
