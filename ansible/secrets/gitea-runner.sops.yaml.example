# Gitea Actions ORG runner-registration token for the act_runner pool (git.chifor.me).
#
# 1. In Gitea, go to the org's runner settings and create a runner token:
#        {{instance}}/org/<org>/settings/actions/runners  →  "Create new Runner"
#    Copy the token (a random string; reusable to register many runners until it is reset).
# 2. Copy this file to `gitea-runner.sops.yaml` and paste the token below.
# 3. Encrypt IN PLACE (the .sops.yaml rule encrypts only `gitea_runner_registration_token`):
#        SOPS_AGE_KEY_FILE=kubernetes/infra/_out/age.agekey \
#          sops --encrypt --in-place ansible/secrets/gitea-runner.sops.yaml
#    Verify it's encrypted (ENC[...]) BEFORE committing — never commit this token in plaintext.
#
# The instance URL + label are NOT secret -> set them in ansible/group_vars/gitea_runners.yml / role defaults.
gitea_runner_registration_token: "paste-the-gitea-org-runner-token-here"
