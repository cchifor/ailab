# MANAGED BY ANSIBLE (role: gitea_runner). Sourced by /usr/local/bin/gitea-runner-reclaim.sh (both the
# ExecStartPre of {{ gitea_runner_service }} and the gitea-runner-reclaim.timer). Plain shell KEY=VALUE.
GITEA_RUNNER_SERVICE={{ gitea_runner_service }}
GITEA_RUNNER_WORKDIR_PARENT={{ gitea_runner_workdir_parent }}
GITEA_RUNNER_USER={{ gitea_runner_user }}
GITEA_RUNNER_GROUP={{ gitea_runner_group }}
GITEA_RUNNER_CONFIG_DIR={{ gitea_runner_config_dir }}
# Space-separated artifact subdirs to reclaim. KEEP IN SYNC with the platform job-started hook.
GITEA_RECLAIM_DIRS="{{ gitea_runner_reclaim_dirs | join(' ') }}"
GITEA_RECLAIM_BEACON={{ gitea_runner_reclaim_beacon | bool | ternary('1', '0') }}
GITEA_RECLAIM_TEXTFILE_DIR={{ gitea_runner_reclaim_textfile_dir }}
