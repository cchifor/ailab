# MANAGED BY ANSIBLE (role: gitea_runner). Sourced by /usr/local/bin/gitea-runner-cleanup.sh (the
# gitea-runner-cleanup.timer oneshot). Plain shell KEY=VALUE. Tune the thresholds/windows here.
GITEA_RUNNER_SERVICE={{ gitea_runner_service }}
# Co-located runners sharing this Docker daemon — skip cleanup while ANY of them runs a job.
# Quoted: may be space-separated; sourced by the shell.
GITEA_CLEANUP_PEER_SERVICES="{{ gitea_runner_cleanup_peer_services }}"
GITEA_CLEANUP_DISK_PATH={{ gitea_runner_cleanup_disk_path }}
# Steady-state retention: images/build-cache used within this window are KEPT (avoids re-pull/rebuild churn).
GITEA_CLEANUP_ROUTINE_UNTIL={{ gitea_runner_cleanup_routine_until }}
# disk% >= PRESSURE_PCT -> tighten the retention window to PRESSURE_UNTIL.
GITEA_CLEANUP_PRESSURE_PCT={{ gitea_runner_cleanup_pressure_pct }}
GITEA_CLEANUP_PRESSURE_UNTIL={{ gitea_runner_cleanup_pressure_until }}
# disk% >= CRITICAL_PCT -> hard CRITICAL_UNTIL window (still protects a <1h live build) + actcache trim.
GITEA_CLEANUP_CRITICAL_PCT={{ gitea_runner_cleanup_critical_pct }}
GITEA_CLEANUP_CRITICAL_UNTIL={{ gitea_runner_cleanup_critical_until }}
# Reap RUNNING containers older than this many seconds (> job timeout), except the buildx/buildkit builder.
GITEA_CLEANUP_REAP_AGE_SEC={{ gitea_runner_cleanup_reap_age_sec }}
# Quoted: the '|' alternation would otherwise be parsed as a shell pipe when the env file is sourced.
GITEA_CLEANUP_INFRA_EXCLUDE_RE="{{ gitea_runner_cleanup_infra_exclude_re }}"
GITEA_CLEANUP_ACTCACHE_DIR={{ gitea_runner_cache_dir }}
GITEA_CLEANUP_ACTCACHE_MAX_MB={{ gitea_runner_cleanup_actcache_max_mb }}
GITEA_CLEANUP_BEACON={{ gitea_runner_cleanup_beacon | bool | ternary('1', '0') }}
GITEA_CLEANUP_TEXTFILE_DIR={{ gitea_runner_reclaim_textfile_dir }}
