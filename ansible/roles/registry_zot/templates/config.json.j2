{
  "distSpecVersion": "1.1.0",
  "storage": {
    "rootDirectory": "{{ registry_zot_data_dir }}",
    "gc": true,
    "gcDelay": "2h",
    "gcInterval": "1h",
    "dedupe": true,
    "retention": {
      "dryRun": false,
      "policies": [
        {
          "repositories": ["strive/**"],
          "deleteUntagged": true,
          "keepTags": [
            { "patterns": ["^latest$"] },
            { "patterns": ["^sha-.*"], "mostRecentlyPushedCount": {{ registry_zot_strive_keep_recent }} }
          ]
        },
        {
          "repositories": ["**"],
          "deleteUntagged": false,
          "keepTags": [{ "patterns": [".*"] }]
        }
      ]
    }
  },
  "http": {
    "address": "0.0.0.0",
    "port": "{{ registry_zot_port }}",
    "externalUrl": "https://{{ registry_zot_hostname }}",
    "tls": {
      "cert": "{{ registry_zot_config_dir }}/certs/tls.crt",
      "key": "{{ registry_zot_config_dir }}/certs/tls.key"
    },
    "auth": {
      "htpasswd": {
        "path": "{{ registry_zot_config_dir }}/htpasswd"
      }{% if registry_zot_oidc_enabled %},
      "openid": {
        "providers": {
          "{{ registry_zot_oidc_provider_key }}": {
            "name": "Authelia",
            "issuer": "{{ registry_zot_oidc_issuer }}",
            "clientid": "{{ registry_zot_oidc_client_id }}",
            "clientsecret": "{{ registry_oidc_client_secret }}",
            "keypath": "",
            "scopes": ["openid", "profile", "email", "groups"]
          }
        }
      }{% endif %}
    },
    "accessControl": {
      "repositories": {
        "**": {
          "anonymousPolicy": ["read"],
          "policies": [
            {
              "users": ["{{ registry_zot_ci_user }}"],
              "actions": ["read", "create", "update", "delete"]
            }{% if registry_zot_admin_group %},
            {
              "groups": ["{{ registry_zot_admin_group }}"],
              "actions": ["read", "create", "update", "delete"]
            }{% endif %}
          ]
        }
      }{% if registry_zot_admin_group %},
      "adminPolicy": {
        "groups": ["{{ registry_zot_admin_group }}"],
        "actions": ["read", "create", "update", "delete"]
      }{% endif %}
    }
  },
  "log": {
    "level": "info"
  },
  "extensions": {
    "search": {
      "enable": true
    },
    "ui": {
      "enable": true
    },
    "sync": {
      "enable": true,
{% if registry_zot_sync_dockerhub_user | length > 0 %}
      "credentialsFile": "{{ registry_zot_sync_credentials_file }}",
{% endif %}
      "registries": [
        {
          "urls": ["https://quay.io"],
          "onDemand": true,
          "tlsVerify": true,
          "content": [{ "prefix": "keycloak/**" }]
        },
        {
          "urls": ["https://mcr.microsoft.com"],
          "onDemand": true,
          "tlsVerify": true,
          "content": [{ "prefix": "playwright" }, { "prefix": "playwright/**" }]
        },
        {
          "urls": ["https://mirror.gcr.io", "https://registry-1.docker.io"],
          "onDemand": true,
          "tlsVerify": true,
          "content": [{ "prefix": "**" }]
        }
      ]
    }
  }
}
