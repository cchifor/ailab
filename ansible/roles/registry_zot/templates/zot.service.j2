[Unit]
Description=zot OCI registry ({{ registry_zot_hostname }})
After=network-online.target
Wants=network-online.target

[Service]
User={{ registry_zot_user }}
Group={{ registry_zot_group }}
ExecStart=/usr/local/bin/zot serve {{ registry_zot_config_dir }}/config.json
Restart=on-failure
RestartSec=5
# Let the non-root zot user bind the privileged port 443.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths={{ registry_zot_data_dir }}

[Install]
WantedBy=multi-user.target
