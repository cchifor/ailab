# {{ ansible_managed }} (role: dev_worker) — mode 0600, owner {{ dev_worker_agent_user }}.
# AgentForge runtime config + secrets. Secrets live ONLY in the orchestrator process: the app
# scrubs them from agent-subprocess and repo-test_cmd child envs (ADR 0018 privilege model — under
# one UID that scrubbing is hygiene, not a boundary; see the ADR's threat model).
AF_WORKER_NAME={{ inventory_hostname }}
AF_PORT={{ dev_worker_agentforge_port }}
AF_METRICS_PORT={{ dev_worker_agentforge_metrics_port }}
AF_GITEA_URL=https://git.chifor.me
AF_CONFIG_REPO={{ dev_worker_agentforge_config_repo }}
AF_LITELLM_BASE={{ dev_worker_agentforge_litellm_base }}
AF_LITELLM_KEY={{ dev_worker_agentforge_litellm_key }}
AF_WEBHOOK_SECRET={{ dev_worker_agentforge_webhook_secret }}
AF_BOT_TOKEN_PLANNER={{ dev_worker_agentforge_planner_token }}
AF_BOT_TOKEN_TESTER={{ dev_worker_agentforge_tester_token }}
AF_BOT_TOKEN_IMPL={{ dev_worker_agentforge_impl_token }}
AF_BOT_TOKEN_REVIEWER={{ dev_worker_agentforge_reviewer_token }}
