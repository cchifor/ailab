#!/usr/bin/env bash
# {{ ansible_managed }} (role: dev_worker)
# Compact GitHub Actions view: status icon + workflow name only.
REPOS=(
{% for r in dev_worker_gh_fleet_repos | default(['cchifor/platform']) %}
  {{ r }}
{% endfor %}
)
for r in "${REPOS[@]}"; do
  printf '\033[1;36m═══ %s ═══\033[0m\n' "$r"
  gh run list --repo "$r" --limit 10 \
    --json conclusion,status,workflowName \
    --jq '.[] | "\(.conclusion)|\(.status)|\(.workflowName)"' 2>/dev/null \
  | while IFS='|' read -r conc status name; do
      st="${conc:-$status}"   # in-progress runs report conclusion="" — fall back to status
      case "$st" in
        success)         printf '\033[32m✓\033[0m %s\n' "$name" ;;
        failure)         printf '\033[31m✗\033[0m %s\n' "$name" ;;
        cancelled)       printf '\033[35m∅\033[0m %s\n' "$name" ;;
        skipped)         printf '\033[37m⊘\033[0m %s\n' "$name" ;;
        timed_out)       printf '\033[31m⌛\033[0m %s\n' "$name" ;;
        action_required) printf '\033[33m!\033[0m %s\n' "$name" ;;
        neutral)         printf '\033[37m·\033[0m %s\n' "$name" ;;
        startup_failure) printf '\033[31m⚠\033[0m %s\n' "$name" ;;
        in_progress)     printf '\033[33m⋯\033[0m %s\n' "$name" ;;
        queued)          printf '\033[33m·\033[0m %s\n' "$name" ;;
        *)               printf '? %s\n' "$name" ;;
      esac
    done
done
