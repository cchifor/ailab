#!/bin/sh
# Managed by Ansible (storage_router). Route + SNAT Talos-VM storage traffic onto the TB/USB fabric so
# the VM reaches the QNAP service IP without a 2nd NIC. Idempotent; run by storage-router.timer every
# 30s so it self-heals after a Thunderbolt flap / reboot (the storage iface enumerates late). SNAT is
# MANDATORY: the QNAP has no return route to {{ vm_subnet }}, so the VM source must be rewritten to
# this host's storage IP for replies to come back over the fabric.
set -eu

IFACE="{{ storage_iface }}"          # this host's storage link (thunderbolt0 / USB-NIC)
SRCNAT="{{ storage_ip }}"            # SNAT VM traffic to this host's fabric IP
SVC="{{ storage_service_ip }}"       # QNAP NFS/iSCSI service IP
VMNET="{{ vm_subnet }}"              # Talos VM / mgmt subnet to forward

# Runtime forwarding (persistent drop-in is installed separately).
[ "$(cat /proc/sys/net/ipv4/ip_forward)" = "1" ] || echo 1 > /proc/sys/net/ipv4/ip_forward

# Do nothing until the storage link exists (TB enumerates late post-boot / after a QNAP reboot).
ip link show "$IFACE" >/dev/null 2>&1 || exit 0

# SNAT VM->service traffic leaving the storage iface to this host's fabric IP.
iptables -t nat -C POSTROUTING -s "$VMNET" -d "$SVC" -o "$IFACE" -j SNAT --to-source "$SRCNAT" 2>/dev/null \
  || iptables -t nat -A POSTROUTING -s "$VMNET" -d "$SVC" -o "$IFACE" -j SNAT --to-source "$SRCNAT"

# Allow the forward both ways (Proxmox FORWARD policy is usually ACCEPT; be explicit so a hardened
# host still works).
iptables -C FORWARD -s "$VMNET" -d "$SVC" -o "$IFACE" -j ACCEPT 2>/dev/null \
  || iptables -A FORWARD -s "$VMNET" -d "$SVC" -o "$IFACE" -j ACCEPT
iptables -C FORWARD -d "$VMNET" -i "$IFACE" -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT 2>/dev/null \
  || iptables -A FORWARD -d "$VMNET" -i "$IFACE" -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
