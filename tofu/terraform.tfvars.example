# Copy to terraform.tfvars (gitignored) and fill in. See docs/runbooks/00-access-prereqs.md.

pve_endpoint     = "https://192.168.0.2:8006/"
pve_api_token    = "tofu@pve!tofu=00000000-0000-0000-0000-000000000000"
pve_insecure     = true
pve_ssh_username = "root"
pve_ssh_key_path = "~/.ssh/id_ed25519"
pve_nodes        = ["ai-node1", "ai-node2", "ai-node3"]

# Filled after the QNAP storage runbook:
qnap_nfs_server = "10.55.0.254"     # QNAP tbtbr0 (service IP); LAN fallback "192.168.1.225"
qnap_nfs_export = "/pve-nfs"        # QuTS hero exports the share at /<sharename>
